# Puerto HTTP de la API. En el deploy, Caddy proxya a este puerto dentro de la red Docker.
PORT=3000

# Entorno de ejecución: development | production
# En production se desactiva pino-pretty (logs JSON crudos para CloudWatch/journald).
NODE_ENV=development

# Conexión a Postgres (Prisma). En dev apunta al contenedor de compose.dev.yaml.
# En deploy apunta al Postgres del compose productivo (o RDS en el futuro).
DATABASE_URL=postgresql://ready:ready@localhost:5433/ready?schema=public

# Usuario único del MVP (single-user). DEBE coincidir con el id sembrado por el seed
# y con el que inyecta el guard @CurrentUser (src/shared/auth).
MVP_USER_ID=00000000-0000-0000-0000-000000000001

# Solo deploy (EC2): hostname que Caddy usa para emitir el cert TLS y rutear.
# Sin dominio propio se usa nip.io sobre la Elastic IP, con guiones en vez de puntos.
# Ej.: si la Elastic IP es 13.52.1.7 → DOMAIN=13-52-1-7.nip.io
DOMAIN=changeme.nip.io

# --- Almacenamiento de imágenes (S3 / MinIO) ---
# Bucket de imágenes de prendas. En AWS: crear el bucket con este nombre.
S3_BUCKET_NAME=ready-uploads
# Región AWS del bucket (en MinIO local es indistinta pero debe estar seteada).
AWS_REGION=us-east-1
# Endpoint S3-compatible. LOCAL (MinIO): http://localhost:9000. AWS real: DEJAR VACÍO.
S3_ENDPOINT=http://localhost:9000
# Path-style URLs: true para MinIO; false (o vacío) para AWS S3.
S3_FORCE_PATH_STYLE=true
# Credenciales del bucket. LOCAL (MinIO): ready/readysecret. AWS: usar IAM (o dejar vacío
# para tomar el IAM role de la instancia). NUNCA commitear credenciales reales.
S3_ACCESS_KEY=ready
S3_SECRET_KEY=changeme
# Base pública desde la que se sirven las imágenes (apunta al propio API).
# LOCAL: http://localhost:3000. DEPLOY: https://<DOMAIN>.
IMAGE_PUBLIC_BASE_URL=http://localhost:3000
